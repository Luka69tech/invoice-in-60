# Stripe Keys (get from https://dashboard.stripe.com/test/apikeys)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create products in Stripe dashboard)
NEXT_PUBLIC_PRICE_STARTER=price_...
NEXT_PUBLIC_PRICE_PRO=price_...

# AI: Ollama endpoint (local by default)
NEXT_PUBLIC_OLLAMA_URL=http://localhost:11434/api/generate

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL_PROD=https://invoicegen.example.com

# Analytics (optional)
NEXT_PUBLIC_POSTHOG_KEY=phc_...
POSTHOG_HOST=https://app.posthog.com

# Upstash Redis (optional, for rate limiting)
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# Email (Resend)
RESEND_API_KEY=re_...
