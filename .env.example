# ============================================================
# Invoice In 60 — Environment Variables
# ============================================================
# Copy this file to .env.local for local development
# For Vercel: set in dashboard → Settings → Environment Variables
#
# NEVER commit .env.local or .env.local.build to git!
# ============================================================

# ===== PAYMENTO CRYPTO PAYMENT GATEWAY =====
# Get from: https://app.paymento.io → Settings → API Keys
# API Key: your live API key for creating payment requests
# Secret Key: used to verify webhook signatures (IPN callbacks)
# Webhook URL to set in Paymento dashboard:
#   https://invoice-in-60.vercel.app/api/webhooks/paymento
# Webhook signature header: "paymento-signature" or "x-paymento-signature"
PAYMENTO_API_KEY=your_paymento_api_key_here
PAYMENTO_SECRET_KEY=your_paymento_webhook_secret_here
PAYMENTO_API_URL=https://api.paymento.io
PAYMENTO_GATEWAY_URL=https://app.paymento.io/gateway

# ===== RESEND EMAIL =====
# Used for: payment confirmation emails with PDF receipt
# Get from: https://resend.com → API Keys
# From address must be verified in Resend (e.g. invoices@yourdomain.com)
RESEND_API_KEY=your_resend_api_key_here

# ===== UPSTASH REDIS =====
# Used for: usage tracking, rate limiting, session storage
# Get from: https://console.upstash.com/ → your database → REST API
# Local: use your development database
# Vercel: set in Vercel dashboard Environment Variables
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# ===== OLLAMA (AI Invoice Suggestions) =====
# Used for: AI-powered line item suggestions in the builder
# Local dev: http://localhost:11434/api/generate
# Production: use a remote Ollama instance or remove feature
OLLAMA_URL=http://localhost:11434/api/generate

# ===== TELEGRAM BOT (Notifications) =====
# Used for: receiving payment notifications in Telegram
# Get Bot Token: message @BotFather on Telegram
# Get Chat ID: message @userinfobot or check @getidsbot
# Set these in Vercel dashboard: Settings → Environment Variables
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ===== ADMIN PASSWORD =====
# Used for: accessing /admin/monitoring dashboard
# Set this in Vercel: Settings → Environment Variables
ADMIN_PASSWORD=your_admin_password_here

# ===== CRON SECRET =====
# Used for: authenticating cron job endpoints (monitor + digest)
# Set this in Vercel: Settings → Environment Variables
# Generate with: openssl rand -base64 32
# When calling cron endpoints externally, use:
#   curl -H "Authorization: Bearer <CRON_SECRET>" https://invoice-in-60.vercel.app/api/cron/monitor
CRON_SECRET=your_cron_secret_here

# ===== APP URLs =====
# Local development
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production (update this when you have a custom domain)
NEXT_PUBLIC_APP_URL_PROD=https://invoice-in-60.vercel.app

# ===== CRYPTO WALLET ADDRESSES =====
# These are PUBLICLY exposed (client-side JavaScript)
# Only needed if you're accepting that specific crypto
NEXT_PUBLIC_CRYPTO_BTC=
NEXT_PUBLIC_CRYPTO_ETH=
NEXT_PUBLIC_CRYPTO_SOL=
NEXT_PUBLIC_CRYPTO_USDT_ERC20=
NEXT_PUBLIC_CRYPTO_USDT_TRC20=
NEXT_PUBLIC_CRYPTO_USDT_SOL=
NEXT_PUBLIC_CRYPTO_USDC_ERC20=
NEXT_PUBLIC_CRYPTO_USDC_SOL=