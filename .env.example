# ===== PAYMENTO CRYPTO PAYMENT =====
# Get these from https://app.paymento.io
PAYMENTO_API_KEY=your_paymento_api_key
PAYMENTO_SECRET_KEY=your_paymento_secret_key
PAYMENTO_API_URL=https://api.paymento.io
PAYMENTO_GATEWAY_URL=https://app.paymento.io/gateway

# ===== RESEND EMAIL (for payment confirmations) =====
# Get from https://resend.com
RESEND_API_KEY=re_deNfum1r_B7RSWGUCBctmXZbgRbCBagL8

# AI: Ollama endpoint (server-side only — NOT exposed to client)
# Local dev: OLLAMA_URL=http://localhost:11434/api/generate
# Vercel prod: set in Vercel dashboard Environment Variables (not .env.local)
OLLAMA_URL=http://localhost:11434/api/generate

# Upstash Redis (server-side only — anti-abuse rate limiting)
# Local dev: get from https://console.upstash.com/ → your database → REST API
# Vercel prod: set in Vercel dashboard Environment Variables
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL_PROD=https://your-domain.vercel.app